NODE_ENV=production
PORT=3000

# REQUIRED in production
ADMIN_USERNAME=change_me
ADMIN_PASSWORD=change_me
CHAT_ENCRYPTION_KEYS=primary:change_me_primary_key,legacy:change_me_legacy_key
CHAT_ENCRYPTION_ACTIVE_KEY_ID=primary

# Backward compatibility for old setups (optional)
CHAT_ENCRYPTION_KEY=
ALLOWED_ORIGINS=https://app.assist4web.com

# Optional hardening (recommended)
ENFORCE_HTTPS=true
MOBILE_API_KEY=

# Optional Firebase path
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
